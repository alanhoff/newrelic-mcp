{
  "name": "newrelic-mcp",
  "version": "1.0.0",
  "main": "./index.js",
  "scripts": {
    "test:unit": "node --env-file=.env.test --test \"index.test.js\" \"lib/**/*.test.js\" \"tools/**/*.test.js\" \"test/**/*-test.js\" \"test/**/*.test.js\"",
    "test": "biome check && npm run --silent test:unit",
    "fix": "biome check --fix",
    "test:coverage": "biome check && c8 --check-coverage --lines 95 --functions 95 --branches 80 --reporter=text-summary --reporter=lcov --reporter=json-summary --reports-dir coverage --include \"index.js\" --include \"lib/**/*.js\" --include \"tools/**/*.js\" --exclude \"test/**\" --exclude \"**/*.test.js\" --exclude \"**/*-test.js\" npm run --silent test:unit"
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "bin": "./index.js",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.1",
    "graphql": "^16.12.0",
    "lodash": "^4.17.21",
    "map-obj": "^6.0.0",
    "moment": "^2.30.1",
    "serialize-error": "^12.0.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.6",
    "c8": "^11.0.0",
    "chai": "^6.2.1",
    "expect": "^30.2.0"
  }
}
